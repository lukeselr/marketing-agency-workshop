    "ec4l_checkbox": "label:has-text('Enhanced conversions for leads') input[type='checkbox']",
    "submit": "button:has-text('Save and continue')"
  },
  "campaign": {
    "name": "label:has-text('Campaign name') input",
    "status_select": "label:has-text('Status') select",
    "bid_strategy_select": "label:has-text('Bid strategy') select",
    "submit": "button:has-text('Save'),button:has-text('Create campaign')"
  }
