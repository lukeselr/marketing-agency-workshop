    "timezone": "label:has-text('Time zone') select",
    "currency": "label:has-text('Currency') select",
    "submit": "button:has-text('Submit'),button:has-text('Continue')"
  },
  "developer_token": {
    "apply_button": "button:has-text('Apply for token')",
    "use_case": "label:has-text('Use case') textarea",
    "agree": "input[type='checkbox']",
    "submit": "button:has-text('Submit')",
    "token_display": "[data-testid='developer-token']"
  },
  "oauth": {
    "configure_consent": "button:has-text('Configure consent screen')",
    "external_radio": "input[type='radio']:near(:text('External'))",
